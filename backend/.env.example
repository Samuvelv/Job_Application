# backend/.env.example
# Copy to .env and fill in real values before running locally or via Docker.

NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talentdb
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT — use long random strings (min 64 chars each)
JWT_SECRET=your_jwt_secret_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# SMTP — leave blank to use Ethereal auto-inbox (dev only, preview at ethereal.email)
# Fill in real values to send actual emails:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=TalentHub <your@gmail.com>

# URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200

# Cloudinary — get values from https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
