# backend/.env.example
# Copy to .env and fill in real values before running locally or via Docker.

NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talentdb
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT — use long random strings (min 64 chars each)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars_long
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_string_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# SMTP (example: Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=TalentHub <your_email@gmail.com>

# URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
